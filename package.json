{
  "name": "backlog-sprinter",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "build": "NODENV=production webpack; cd dist; zip ../backlog-sprinter.zip -r *; yarn secret",
    "once": "webpack",
    "watch": "webpack --watch",
    "wsl": "DST_DIR=$(echo $PATH | grep -o '/mnt/c/Users/[a-zA-Z]*' | head -n 1)/dev/bnn/backlog-sprinter/dist yarn watch",
    "test": "jest",
    "secret": "cp public/manifest.json ../backlog-sprinter-secret/public; cp src/backlog-api-keys.ts ../backlog-sprinter-secret/src",
    "import-secret": "cp ../backlog-sprinter-secret/public/manifest.json public/manifest.json; cp ../backlog-sprinter-secret/src/backlog-api-keys.ts src/backlog-api-keys.ts"
  },
  "eslintConfig": {
    "env": {
      "webextensions": true,
      "browser": true
    },
    "plugins": [
      "react",
      "react-hooks",
      "@typescript-eslint"
    ],
    "rules": {
      "react-hooks/rules-of-hooks": "error",
      "react-hooks/exhaustive-deps": "warn"
    },
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/eslint-recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:react/recommended",
      "plugin:react-hooks/recommended"
    ],
    "ignorePatterns": [
      "webpack.config.js",
      "node_modules"
    ],
    "settings": {
      "react": {
        "version": "detect"
      }
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^4.9.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.200",
    "@types/copy-webpack-plugin": "^8.0.1",
    "@types/jest": "^28.1.7",
    "@types/jquery": "^3.5.14",
    "@types/node": "^18.11.9",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.9",
    "@types/webpack": "^5.28.0",
    "@typescript-eslint/eslint-plugin": "^5.45.1",
    "@typescript-eslint/parser": "^5.45.1",
    "copy-webpack-plugin": "^10.0.0",
    "eslint": "^8.3.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-react": "^7.31.11",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-webpack-plugin": "^3.2.0",
    "husky": "^8.0.2",
    "jest": "^28.1.3",
    "lint-staged": "^13.0.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.1",
    "prettier-plugin-organize-imports": "^3.2.1",
    "prettier-webpack-plugin": "^1.2.0",
    "ts-jest": "^28.0.8",
    "ts-loader": "^9.2.6",
    "webpack": "^5.64.4",
    "webpack-cli": "^4.9.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "./**/*.{js,jsx,ts,tsx,json}": [
      "yarn lint:fix"
    ]
  },
  "prettier": {
    "semi": false,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "none",
    "printWidth": 120
  }
}
